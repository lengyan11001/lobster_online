    "goal_video_pipeline_skill": {
      "name": "创意成片",
      "description": "根据用户目标和记忆自动生成文案、图片和宣传短视频，完成后返回素材库 final_asset_id，适合“根据我的记忆给某产品生成抖音视频”。",
      "type": "builtin",
      "store_visibility": "popular",
      "default_installed": true,
      "status": "installed",
      "capabilities": {
        "goal.video.pipeline": {
          "description": "创意成片：当用户只给目标、产品名或要求，并希望结合记忆自动生成宣传短视频/图生视频时使用。不要因为素材库没有产品图而停止；本能力会先检索记忆，生成文案、图片提示词和视频提示词，再调用 image.generate 生成图片、video.generate 生成视频，完成后返回 final_asset_id/video_asset_id。",
          "upstream": "local",
          "upstream_tool": "invoke",
          "enabled": true,
          "is_default": false,
          "unit_credits": 0,
          "arg_schema": {
            "type": "object",
            "properties": {
              "action": {
                "type": "string",
                "enum": [
                  "run_pipeline",
                  "start_pipeline",
                  "poll_pipeline"
                ],
                "default": "start_pipeline",
                "description": "默认用 start_pipeline开启异步任务，MCP 会自动轮询结果"
              },
              "goal": {
                "type": "string",
                "description": "用户的目标原文，例如：根据我的记忆，给某产品生成 8 秒抖音 9:16 宣传视频"
              },
              "job_id": {
                "type": "string",
                "description": "poll_pipeline 时传入 start_pipeline 返回的 job_id"
              },
              "platform": {
                "type": "string",
                "default": "douyin",
                "description": "目标平台，例如 douyin/xiaohongshu/toutiao"
              },
              "language": {
                "type": "string",
                "default": "??",
                "description": "生成语言"
              },
              "duration": {
                "type": "integer",
                "default": 8,
                "description": "视频时长，默认 8 秒"
              },
              "aspect_ratio": {
                "type": "string",
                "default": "9:16",
                "description": "视频比例，抖音默认 9:16"
              },
              "memory_scope": {
                "type": "string",
                "default": "default",
                "description": "记忆检索范围，默认用当前用户/代理商记忆"
              },
              "planning_model": {
                "type": "string",
                "description": "可选，指定规划文案模型"
              },
              "image_model": {
                "type": "string",
                "description": "可选，指定生图模型；不填则使用 image.generate 默认模型"
              },
              "video_model": {
                "type": "string",
                "description": "可选，指定视频模型；不填则使用 video.generate 默认模型"
              },
              "reference_asset_ids": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "可选参考素材 ID；没有产品图时可留空，不要阻止流程"
              },
              "reference_image_urls": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "可选参考图 URL；没有可留空"
              },
              "image_retry_count": {
                "type": "integer",
                "default": 2
              },
              "video_retry_count": {
                "type": "integer",
                "default": 2
              }
            },
            "required": [
              "goal"
            ]
          }
        }
      },
      "tags": [
        "OpenClaw",
        "video",
        "image",
        "memory",
        "workflow"
      ]
    }
